{
    "identifier": "default",
    "description": "Default capabilities for the DAQ app",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "core:webview:default",
        "core:webview:allow-internal-toggle-devtools",
        "core:window:default",
        "core:window:allow-close",
        "core:window:allow-set-title",
        "core:event:default",
        "core:event:allow-emit",
        "core:event:allow-listen",
        "core:path:default",
        "dialog:default",
        "dialog:allow-save"
    ]
}